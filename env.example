BOT_TOKEN=your_botfather_token
ADMIN_IDS=123456789,987654321

# Railway usually provides DATABASE_URL automatically when PostgreSQL is attached.
DATABASE_URL=

# Or use split PostgreSQL variables.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tg_anon
POSTGRES_USER=tg_anon
POSTGRES_PASSWORD=tg_anon

REDIS_URL=redis://redis:6379/0

MAX_FILE_SIZE=419430400
SPAM_COOLDOWN=0.7
REMATCH_COOLDOWN=3600
LOW_QUALITY_REPUTATION=40
REPORT_REPUTATION_PENALTY=3
MIN_AGE=13
MAX_AGE=99
STATUS_MAX_LENGTH=60
LOG_LEVEL=INFO
